{
  "$schema": "https://tr.designtokens.org/format/",
  "$description": "Kenius — Atelier (luxury-minimal) design tokens. Source of truth; assets/css/lux.css mirrors these (hex fallback + OKLCH).",
  "color": {
    "paper":     { "$type": "color", "$value": "oklch(94.6% 0.008 91.5)", "hex": "#EFEDE7", "$description": "bone canvas" },
    "paper-2":   { "$type": "color", "$value": "oklch(91.8% 0.011 95.2)", "hex": "#E6E4DC" },
    "ink":       { "$type": "color", "$value": "oklch(21.7% 0.006 106.9)", "hex": "#1A1A17", "$description": "near-black text" },
    "ink-soft":  { "$type": "color", "$value": "oklch(38.3% 0.012 93.8)", "hex": "#45433C", "$description": "body text" },
    "muted":     { "$type": "color", "$value": "oklch(43.9% 0.017 88.8)", "hex": "#565248", "$description": "captions" },
    "accent":    { "$type": "color", "$value": "oklch(46.1% 0.071 78.2)", "hex": "#6E5326", "$description": "bronze — marks/hover only" },
    "dark":      { "$type": "color", "$value": "oklch(18.3% 0.004 84.6)", "hex": "#131210", "$description": "dark interlude bg" },
    "dark-text": { "$type": "color", "$value": "oklch(93.1% 0.014 88.7)", "hex": "#ECE8DE" }
  },
  "typography": {
    "display": { "$type": "fontFamily", "$value": "Bodoni Moda", "$description": "high-contrast didone, true italics for emphasis" },
    "body":    { "$type": "fontFamily", "$value": "General Sans" }
  },
  "radius": { "input": { "$type": "dimension", "$value": "0px" }, "button": { "$type": "dimension", "$value": "3px" } }
}
