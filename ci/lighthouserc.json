{
  "ci": {
    "collect": {
      "staticDistDir": ".",
      "numberOfRuns": 1,
      "settings": { "preset": "desktop" }
    },
    "assert": {
      "_comment": "axe (ci/a11y.mjs) is the hard accessibility gate; Lighthouse is informational — CI-runner perf is noisy, so warn rather than block.",
      "assertions": {
        "categories:performance":     ["warn", { "minScore": 0.9 }],
        "categories:accessibility":   ["warn", { "minScore": 1.0 }],
        "categories:best-practices":  ["warn", { "minScore": 0.95 }],
        "categories:seo":             ["warn", { "minScore": 0.9 }]
      }
    }
  }
}
