---
// Kenius v3 — the one shared shell (was duplicated across 5 HTML files).
// Unified nav fixes B1 (About was unreachable from the homepage).
interface Props { title: string; description: string; path: string; }
const { title, description, path } = Astro.props;
const nav = [
  { href: '/services', label: 'Services' },
  { href: '/work', label: 'Work' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
const canonical = `https://kenius.us${path === '/' ? '' : path}`;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#EFEDE7" />
  <link rel="canonical" href={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <link rel="icon" href="/favicon.svg" />
  <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,400..600;1,6..96,400..600&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link href="https://api.fontshare.com/v2/css?f[]=general-sans@300,400,500,600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/assets/css/lux.css" />
  <noscript><style>.reveal{opacity:1!important;transform:none!important}</style></noscript>
</head>
<body>
  <a class="skip" href="#main">Skip to content</a>
  <header class="hdr">
    <div class="wrap nav">
      <a class="brand" href="/">Kenius<sup>®</sup></a>
      <nav class="nav-mid" aria-label="Primary">
        {nav.map(item => (
          <a href={item.href} aria-current={path === item.href ? 'page' : undefined}>{item.label}</a>
        ))}
      </nav>
      <div class="nav-right">
        <a class="tlink nav-cta" href="/contact#form">Book a call <span class="ar" aria-hidden="true">↗</span></a>
        <button class="menu-btn" aria-expanded="false" aria-controls="overlay">Menu <span class="bars" aria-hidden="true"><span></span><span></span><span></span></span></button>
      </div>
    </div>
  </header>
  <div class="overlay" id="overlay">
    {nav.map(item => <a href={item.href}>{item.label}</a>)}
    <a href="/contact#form">Book a call ↗</a><span class="cap">hello@kenius.us</span>
  </div>

  <main id="main">
    <slot />
  </main>

  <footer class="foot">
    <div class="wrap">
      <div class="foot-grid">
        <div>
          <a class="brand" href="/">Kenius<sup>®</sup></a>
          <p style="max-width:34ch;margin-top:1.2rem;color:var(--muted);font-size:.95rem">We find where AI belongs in your business — then build it, quietly, and hand it over.</p>
        </div>
        <div class="foot-col">
          <p class="foot-h">Index</p>
          <a href="/services">Services</a><a href="/work">Work</a><a href="/about">About</a><a href="/">Home</a>
        </div>
        <div class="foot-col">
          <p class="foot-h">Contact</p>
          <a href="mailto:hello@kenius.us">hello@kenius.us</a><a href="/contact#form">Book a call ↗</a><a href="#" aria-label="Kenius on LinkedIn">LinkedIn ↗</a>
        </div>
      </div>
      <div class="foot-bottom">
        <span>© <span data-year>2026</span> Kenius. Made by humans, with help from AI.</span><span>kenius.us</span>
      </div>
      <p class="disclaimer">Client names, testimonials, metrics and outcomes shown here are illustrative samples — replace with your own before going live.</p>
    </div>
  </footer>
  <script is:inline defer src="/assets/js/vendor/gsap.min.js"></script>
  <script is:inline defer src="/assets/js/vendor/ScrollTrigger.min.js"></script>
  <script is:inline defer src="/assets/js/vendor/lenis.min.js"></script>
  <script is:inline defer src="/assets/js/lux.js"></script>
  <script is:inline defer src="/assets/js/motion.js"></script>
</body>
</html>
