# Cloudflare Pages headers — https://developers.cloudflare.com/pages/configuration/headers/

# Assets aren't fingerprinted, so revalidate every load (fast 304s via ETag) —
# this means CSS/JS changes show up immediately instead of being cached for a day.
# Bump to a long max-age once the site stabilises for maximum repeat-visit speed.
/assets/*
  Cache-Control: public, no-cache

# Sensible security defaults for a static marketing site.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(), microphone=(), camera=()
